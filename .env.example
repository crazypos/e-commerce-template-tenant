# ── 模板配置 ──
# default：平台标准模板（只读，git pull 更新）
# my-template：自定义模板（需先 cp -rf templates/default templates/my-template）
TEMPLATE=default

# ── API Token（向平台方索取） ──
ADMIN_TOKEN=your_admin_token
STRAPI_TOKEN=your_strapi_token

# ── API 地址 ──
NEXT_PUBLIC_API_URL=https://test3.crazypos.com/api

# ── 站点域名（生产环境需改为实际域名） ──
BASE_URL=http://localhost:3303

# ── 部署 API 地址 ──
# 本地: http://deploy.crazypos.local
# 测试: https://deploy.test.crazypos.com
# 生产: https://deploy.crazypos.com
AUTH_URL=http://e-commerce-deploy-test.crazypos.com/tenant/auth.php
DEPLOY_URL=http://e-commerce-deploy-test.crazypos.com/tenant/api.php
